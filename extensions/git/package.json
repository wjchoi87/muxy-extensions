{
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "muxy": {
    "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
    "description": "Official Git extension for Muxy",
    "permissions": [
      "git:read",
      "git:write",
      "commands:exec",
      "panels:write",
      "tabs:write",
      "worktrees:read",
      "worktrees:write"
    ],
    "events": [
      "project.switched",
      "worktree.switched",
      "file.changed"
    ],
    "panels": [
      {
        "id": "scm",
        "title": "Source Control",
        "entry": "panel/index.html",
        "position": "right",
        "mode": "pinned",
        "hiddenControls": ["icon", "title", "close", "pin", "position"]
      }
    ],
    "tabTypes": [
      {
        "id": "diff-viewer",
        "title": "Diff Viewer",
        "entry": "panel/diff-viewer.html"
      }
    ],
    "commands": [
      {
        "id": "toggle-scm",
        "title": "Toggle Source Control",
        "defaultShortcut": "cmd+y",
        "action": {
          "kind": "togglePanel",
          "panel": "scm"
        }
      },
      {
        "id": "refresh-scm",
        "title": "Refresh"
      }
    ],
    "topbarItems": [
      {
        "id": "scm",
        "icon": {
          "symbol": "arrow.triangle.branch"
        },
        "tooltip": "Toggle Source Control",
        "command": "toggle-scm"
      }
    ],
    "marketplace": {
      "author": "Saeed Vaziry",
      "github": "saeedvaziry",
      "repository": "https://github.com/muxy-app/extensions",
      "categories": ["git", "source-control"],
      "icon": "icon.svg",
      "screenshots": ["screenshots/screenshot-1.png", "screenshots/screenshot-2.png"]
    }
  },
  "name": "git",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && vite build && vite build --config vite.diff-viewer.config.ts && node -e \"require('fs').copyFileSync('package.json','dist/package.json')\"",
    "build:surfaces": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.1",
  "dependencies": {
    "@pierre/diffs": "^1.2.7",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
