{
  "name": "git",
  "private": true,
  "scripts": {
    "build": "vite build && vite build --config vite.diff-viewer.config.js && node -e \"require('fs').copyFileSync('package.json','dist/package.json')\"",
    "build:surfaces": "vite build",
    "dev": "vite",
    "update-skill": "node scripts/update-skill.mjs"
  },
  "type": "module",
  "version": "1.8.2",
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.5"
  },
  "muxy": {
    "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
    "description": "Official Git extension for Muxy — GitHub, Forgejo, and Gitea",
    "permissions": [
      "commands:exec",
      "panels:write",
      "tabs:write",
      "worktrees:read",
      "worktrees:write",
      "notifications:write",
      "files:read",
      "git:write"
    ],
    "events": [
      "project.switched",
      "worktree.switched",
      "file.changed"
    ],
    "panels": [
      {
        "id": "scm",
        "title": "Source Control",
        "entry": "panel/index.html",
        "position": "right",
        "mode": "pinned",
        "hiddenControls": ["icon", "title", "close", "pin", "position"]
      }
    ],
    "tabTypes": [
      {
        "id": "diff-viewer",
        "title": "Diff Viewer",
        "entry": "panel/diff-viewer.html"
      }
    ],
    "commands": [
      {
        "id": "toggle-scm",
        "title": "Toggle Source Control",
        "defaultShortcut": "cmd+y",
        "action": {
          "kind": "togglePanel",
          "panel": "scm"
        }
      },
      {
        "id": "refresh-scm",
        "title": "Refresh"
      }
    ],
    "topbarItems": [
      {
        "id": "scm",
        "icon": {
          "symbol": "arrow.triangle.branch"
        },
        "tooltip": "Toggle Source Control",
        "command": "toggle-scm"
      }
    ],
    "marketplace": {
      "author": "Saeed Vaziry",
      "github": "saeedvaziry",
      "repository": "https://github.com/muxy-app/extensions",
      "categories": ["git", "source-control"],
      "icon": "icon.svg",
      "screenshots": ["screenshots/screenshot-1.png", "screenshots/screenshot-2.png"]
    }
  }
}
