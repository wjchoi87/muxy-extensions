{
  "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
  "name": "clock",
  "version": "0.1.1",
  "description": "A status bar clock. Click it to open a popover with a live, theme-aware clock.",
  "permissions": ["panels:write"],
  "popovers": [
    {
      "id": "clock",
      "title": "Clock",
      "entry": "popovers/clock.html",
      "width": 240,
      "height": 140
    }
  ],
  "commands": [
    {
      "id": "open-clock",
      "title": "Clock: Show",
      "action": { "kind": "openPopover", "popover": "clock" }
    }
  ],
  "statusBarItems": [
    {
      "id": "clock",
      "icon": { "symbol": "clock" },
      "tooltip": "Show the clock",
      "side": "right",
      "command": "open-clock"
    }
  ],
  "marketplace": {
    "author": "Saeed Vaziry",
    "github": "saeedvaziry",
    "categories": ["example", "productivity"],
    "icon": "assets/icon.svg",
    "screenshots": ["assets/screenshot-1.png"]
  }
}
