{
  "name": "files",
  "version": "1.2.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs=require('fs');fs.copyFileSync('package.json','dist/package.json');fs.mkdirSync('dist/scripts',{recursive:true});fs.copyFileSync('scripts/quick-open.js','dist/scripts/quick-open.js')\"",
    "update-skill": "node scripts/update-skill.mjs"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.5"
  },
  "muxy": {
    "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
    "description": "File explorer for Muxy",
    "permissions": [
      "files:read",
      "files:write",
      "panels:write",
      "tabs:write",
      "commands:exec",
      "commands:run-script"
    ],
    "events": [
      "file.changed",
      "worktree.switched",
      "project.switched"
    ],
    "panels": [
      {
        "id": "files",
        "title": "Files",
        "entry": "panel/index.html",
        "position": "right",
        "mode": "pinned",
        "hiddenControls": [
          "pin",
          "position"
        ],
        "icon": {
          "symbol": "folder"
        }
      }
    ],
    "tabTypes": [
      {
        "id": "code-editor",
        "title": "Editor",
        "entry": "panel/editor.html"
      }
    ],
    "commands": [
      {
        "id": "toggle-files",
        "title": "Toggle Files",
        "defaultShortcut": "cmd+e",
        "action": {
          "kind": "togglePanel",
          "panel": "files"
        }
      },
      {
        "id": "files-quick-open",
        "title": "Files: Go to File…",
        "subtitle": "Fuzzy-find a file in the workspace",
        "defaultShortcut": "cmd+p",
        "action": {
          "kind": "runScript",
          "script": "scripts/quick-open.js"
        }
      }
    ],
    "topbarItems": [
      {
        "id": "files",
        "icon": {
          "symbol": "folder"
        },
        "tooltip": "Toggle Files",
        "command": "toggle-files"
      }
    ],
    "marketplace": {
      "author": "Saeed Vaziry",
      "github": "saeedvaziry",
      "repository": "https://github.com/muxy-app/extensions",
      "categories": ["files", "explorer"],
      "icon": "icon.svg",
      "screenshots": ["screenshots/screenshot-1.png", "screenshots/screenshot-2.png"]
    }
  }
}
