{
  "devDependencies" : {
    "@tailwindcss\/vite" : "^4.3.0",
    "tailwindcss" : "^4.3.0",
    "vite" : "^7.3.5"
  },
  "muxy" : {
    "$schema" : "https:\/\/raw.githubusercontent.com\/muxy-app\/muxy\/main\/docs\/extensions\/schema\/manifest.schema.json",
    "background" : "background.js",
    "commands" : [
      {
        "action" : {
          "kind" : "togglePanel",
          "panel" : "ports"
        },
        "defaultShortcut" : "cmd+shift+p",
        "id" : "toggle-ports",
        "title" : "Ports: Toggle Panel"
      },
      {
        "id" : "refresh-ports",
        "title" : "Ports: Refresh"
      }
    ],
    "panels" : [
      {
        "entry" : "panel\/index.html",
        "headerButtons" : [
          {
            "command" : "refresh-ports",
            "icon" : {
              "symbol" : "arrow.clockwise"
            },
            "id" : "refresh",
            "tooltip" : "Refresh"
          }
        ],
        "icon" : {
          "symbol" : "antenna.radiowaves.left.and.right"
        },
        "id" : "ports",
        "mode" : "pinned",
        "position" : "right",
        "title" : "Ports"
      }
    ],
    "permissions" : [
      "panels:write",
      "commands:exec",
      "projects:read"
    ],
    "statusBarItems" : [
      {
        "command" : "toggle-ports",
        "icon" : {
          "symbol" : "antenna.radiowaves.left.and.right"
        },
        "id" : "ports",
        "side" : "right",
        "tooltip" : "Ports"
      }
    ],
    "topbarItems" : [
      {
        "command" : "toggle-ports",
        "icon" : {
          "symbol" : "antenna.radiowaves.left.and.right"
        },
        "id" : "ports",
        "tooltip" : "Toggle Ports Panel"
      }
    ],
    "marketplace" : {
      "author" : "mountain1009",
      "github" : "mountain1009",
      "categories" : [
        "developer-tools",
        "network"
      ],
      "icon" : "icon.svg",
      "screenshots" : [
        "screenshot-1.png"
      ]
    }
  },
  "description" : "View and manage TCP listening ports, grouped by Muxy project",
  "name" : "ports",
  "private" : true,
  "scripts" : {
    "build" : "vite build && node -e \"require('fs').copyFileSync('package.json','dist/package.json')\"",
    "dev" : "vite",
    "update-skill" : "node -e \"const fs=require('fs'),p=require('path');const url='https:\/\/raw.githubusercontent.com\/muxy-app\/muxy\/main\/Muxy\/Resources\/skills\/muxy-extension\/SKILL.md';fetch(url).then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.text()}).then(t=>{for(const d of ['.claude\/skills\/muxy-extension','.agents\/skills\/muxy-extension']){fs.mkdirSync(d,{recursive:true});fs.writeFileSync(p.join(d,'SKILL.md'),t);console.log('Updated '+p.join(d,'SKILL.md'))}}).catch(e=>{console.error('Failed to update skill:',e.message);process.exit(1)})\""
  },
  "type" : "module",
  "version" : "0.1.0"
}
